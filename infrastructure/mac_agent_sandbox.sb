(version 1)
(deny default)

;; Standard process allowances
(allow process-fork)
(allow process-exec)
(allow sysctl-read)

;; --- Network Mandates (Container Expert) ---
;; Allow communicating with the system DNS responder
(allow network-outbound (literal "/private/var/run/mDNSResponder"))

;; Allow binding to local ports (for potential local server/tools)
(allow network-bind)

;; Explicit TCP outbound for Postgres (5432), Redis (6379), and HTTPS/Cloud APIs (443)
(allow network-outbound
    (remote tcp "*:5432")
    (remote tcp "*:6379")
    (remote tcp "*:443")
)

;; --- Filesystem Mandates ---

;; System Library and Python Runtime Access
(allow file-read*
    (subpath "/usr/lib")
    (subpath "/usr/bin")
    (subpath "/usr/sbin")
    (subpath "/System/Library")
    (subpath "/Library/Frameworks")
    (subpath "/Library/Python")
    (subpath "/Library/Managed Preferences")
    (subpath "/private/var/db/timezone")
    (subpath "/private/var/db/mds")
)

;; Project Root Access (Read-Only by default)
(allow file-read*
    (subpath "/Users/raytiongai/projects/agentic-dev")
)

;; Explicit Write access to .data and tmp within project
(allow file-write*
    (subpath "/Users/raytiongai/projects/agentic-dev/.data")
    (subpath "/Users/raytiongai/projects/agentic-dev/tmp")
)

;; Necessary macOS temp and device access
(allow file-read* file-write*
    (subpath "/private/var/folders")
    (subpath "/private/tmp")
    (subpath "/dev")
)
